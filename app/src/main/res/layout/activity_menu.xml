<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_green"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/titleHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HEALTHY\nBITE"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:lineSpacingExtra="2dp" />

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search"
            android:hint="Search here!"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary"
            android:drawableTint="@color/white"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tagBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@color/bg_main"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tagAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingHorizontal="14dp"
            android:gravity="center"
            android:text="Semua"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_tag_selected_green" />

        <TextView
            android:id="@+id/tagHewani"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:paddingHorizontal="14dp"
            android:gravity="center"
            android:text="Hewani"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_tag_unselected_gray" />

        <TextView
            android:id="@+id/tagNabati"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:paddingHorizontal="14dp"
            android:gravity="center"
            android:text="Nabati"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_tag_unselected_gray" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="always"
        app:layout_constraintTop_toBottomOf="@id/tagBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/fabCalculator"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_margin="16dp"
        android:background="@drawable/custom_rounded_button"
        app:srcCompat="@drawable/calculator"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:elevation="6dp"
        android:stateListAnimator="@null"
        android:contentDescription="Kalkulator Kalori"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>