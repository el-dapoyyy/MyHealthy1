<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_result_card_dark"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TAMBAH MAKANAN"
        android:textColor="@color/neon_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/exo2_extrabold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etDialogFoodName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Nama Makanan"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:textColorHint="@color/text_secondary"
        android:background="@drawable/bg_food_name_input"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="12dp"
        android:singleLine="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etDialogCalories"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Kalori"
            android:inputType="number"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/bg_food_name_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="8dp"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.2"
            android:background="@drawable/bg_meal_time_input"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <Spinner
                android:id="@+id/spinnerDialogMealType"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="BATAL"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_button_dark"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="SIMPAN"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button_green"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
