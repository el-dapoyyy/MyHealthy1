<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_green"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Catatan Makan"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:fontFamily="@font/exo2_extrabold" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hari ini"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <!-- Total Kalori -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_white_rounded"
            android:padding="14dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Kalori Hari Ini: "
                android:textColor="#333333"
                android:textSize="14sp"
                android:fontFamily="@font/exo2_extrabold" />

            <TextView
                android:id="@+id/tvTotalCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 kkal"
                android:textColor="#008B02"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Input Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etFoodName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nama makanan"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="14sp"
            android:textColor="#000000"
            android:background="@drawable/bg_input_gray"
            android:textColorHint="#999999"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etCalories"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Kalori (kkal)"
                android:inputType="number"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:background="@drawable/bg_input_gray"
                android:textColorHint="#999999"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <Spinner
                android:id="@+id/spinnerMealType"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_input_gray" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddEntry"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="+ Tambah Catatan"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="@font/exo2_extrabold"
            android:background="@drawable/bg_button_green"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDiary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false" />

</LinearLayout>
