<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp"
        tools:ignore="HardcodedText">

        <!-- Back button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Back"
            android:textColor="@color/neon_primary"
            android:textSize="14sp"
            android:fontFamily="@font/exo2_extrabold"
            android:paddingBottom="10dp" />

        <!-- ═══════════════════════════════════ -->
        <!-- HEADER: METABOLIC ENGINE + CALCULATOR -->
        <!-- ═══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="METABOLIC ENGINE"
            android:textColor="@color/neon_primary"
            android:textSize="11sp"
            android:fontFamily="@font/exo2_extrabold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CALCULATOR"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="@font/exo2_extrabold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp" />

        <!-- Glow divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@drawable/bg_calc_header_divider"
            android:layout_marginBottom="20dp" />

        <!-- ═══════════════════════════════════ -->
        <!-- TDEE RESULT CARD (with glow border) -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calc_tdee_card"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="20dp">

            <!-- Label: DAILY CALORIE TARGET (TDEE) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY CALORIE TARGET (TDEE)"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/exo2_extrabold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <!-- Row: Large calorie + lightning icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- Big calorie number -->
                <TextView
                    android:id="@+id/tvCalorieResult"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="- kkal"
                    android:textColor="@color/neon_primary"
                    android:textSize="42sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:lineSpacingExtra="-4dp" />

                <!-- Lightning bolt circle -->
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp">

                    <View
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_neon_circle_glow" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="⚡"
                        android:textSize="20sp"
                        android:gravity="center" />
                </FrameLayout>
            </LinearLayout>

            <!-- BMI Result -->
            <TextView
                android:id="@+id/tvBmiResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BMI: - (Normal)"
                android:textColor="@color/neon_accent"
                android:fontFamily="@font/exo2_extrabold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <!-- Description text -->
            <TextView
                android:id="@+id/tvResultDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Based on your metrics, this is\nthe estimated energy required\nto maintain your current weight\nwhile active."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!-- BIOLOGICAL GENDER SECTION         -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calc_section_card"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BIOLOGICAL GENDER"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/exo2_extrabold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Gender Spinner -->
            <Spinner
                android:id="@+id/spinnerGender"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_calc_input"
                android:popupBackground="@color/bg_gray_box" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!-- AGE + WEIGHT ROW                  -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp"
            android:weightSum="2">

            <!-- AGE card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_calc_section_card"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AGE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etAge"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:inputType="number"
                        android:background="@drawable/bg_calc_input"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="#4DFFFFFF"
                        android:hint="--"
                        android:textSize="22sp"
                        android:fontFamily="@font/exo2_extrabold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YRS"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/exo2_extrabold"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- WEIGHT card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_calc_section_card"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WEIGHT"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etWeight"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_calc_input"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="#4DFFFFFF"
                        android:hint="--"
                        android:textSize="22sp"
                        android:fontFamily="@font/exo2_extrabold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KG"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/exo2_extrabold"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!-- HEIGHT SECTION (with slider look)  -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calc_section_card"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEIGHT"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/exo2_extrabold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <!-- Neon SeekBar: drag to set height 0-250 cm -->
                <SeekBar
                    android:id="@+id/seekBarHeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="250"
                    android:progress="0"
                    android:progressTint="@color/neon_primary"
                    android:progressBackgroundTint="#0B3A1C"
                    android:thumbTint="@color/neon_primary"
                    android:minHeight="8dp"
                    android:maxHeight="8dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginEnd="16dp" />

                <!-- Value display: number + unit -->
                <EditText
                    android:id="@+id/etHeight"
                    android:layout_width="72dp"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:background="@drawable/bg_calc_input"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#4DFFFFFF"
                    android:hint="--"
                    android:textSize="20sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CM"
                    android:textColor="@color/neon_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!-- ACTIVITY INTENSITY SECTION        -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calc_section_card"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVITY INTENSITY"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/exo2_extrabold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Activity Level Spinner -->
            <Spinner
                android:id="@+id/spinnerActivity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_activity_selected"
                android:popupBackground="@color/bg_gray_box"
                android:layout_marginBottom="8dp" />

            <!-- Goal Spinner -->
            <Spinner
                android:id="@+id/spinnerGoal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_activity_unselected"
                android:popupBackground="@color/bg_gray_box" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!-- MACRO BLUEPRINT SECTION           -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calc_section_card"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="20dp">

            <!-- Label + BALANCED DIET tag -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MACRO BLUEPRINT"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BALANCED DIET"
                    android:textColor="@color/neon_primary"
                    android:textSize="9sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:background="@drawable/bg_tag_neon_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>

            <!-- PROTEIN Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_neon_dot"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PROTEIN"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/exo2_extrabold" />

                <TextView
                    android:id="@+id/tvMacroProtein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protein: -"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/exo2_extrabold" />
            </LinearLayout>

            <!-- Protein bar track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_macro_bar_track" />

                <View
                    android:id="@+id/barProtein"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_macro_bar_green" />
            </FrameLayout>

            <!-- CARBOHYDRATES Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_macro_bar_cyan"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CARBOHYDRATES"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/exo2_extrabold" />

                <TextView
                    android:id="@+id/tvMacroCarb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Karbo: -"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/exo2_extrabold" />
            </LinearLayout>

            <!-- Carb bar track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_macro_bar_track" />

                <View
                    android:id="@+id/barCarb"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_macro_bar_cyan" />
            </FrameLayout>

            <!-- HEALTHY FATS Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_macro_bar_yellow"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HEALTHY FATS"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/exo2_extrabold" />

                <TextView
                    android:id="@+id/tvMacroFat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lemak: -"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/exo2_extrabold" />
            </LinearLayout>

            <!-- Fat bar track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="6dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_macro_bar_track" />

                <View
                    android:id="@+id/barFat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_macro_bar_yellow" />
            </FrameLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!-- RECALCULATE TARGET BUTTON          -->
        <!-- ═══════════════════════════════════ -->
        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_recalculate_btn"
            android:text="⚡ CALCULATE TARGET"
            android:textColor="@color/text_inverse"
            android:textSize="15sp"
            android:fontFamily="@font/exo2_extrabold"
            android:letterSpacing="0.05"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp" />

        <!-- Last updated timestamp -->
        <TextView
            android:id="@+id/tvLastUpdated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LAST CALCULATED: -"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:gravity="center"
            android:alpha="0.5"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>