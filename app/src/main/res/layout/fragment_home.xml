<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:background="@color/bg_main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/titleHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Healthy Bite"
            android:textColor="@color/neon_primary"
            android:textStyle="bold"
            android:textSize="24sp"
            android:fontFamily="@font/exo2_extrabold"
            android:shadowColor="#4D00FF85"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_search"
            android:hint="Cari makanan sehat..."
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary"
            android:drawableTint="@color/neon_primary"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            app:layout_constraintTop_toBottomOf="@id/titleHeader" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- TAG BAR -->
    <LinearLayout
        android:id="@+id/tagBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:background="@color/bg_main"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tagAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:text="Semua"
            android:textStyle="bold"
            android:textColor="@color/bg_main"
            android:background="@drawable/bg_tag_selected_green" />

        <TextView
            android:id="@+id/tagHewani"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:text="Hewani"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_tag_unselected_gray" />

        <TextView
            android:id="@+id/tagNabati"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:text="Nabati"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_tag_unselected_gray" />
    </LinearLayout>

    <!-- SUBTITLE: Katalog Nutrisi (Seperti gambar) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/katalogHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tagBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Katalog Nutrisi"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RECYCLER VIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="10dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="always"
        app:layout_constraintTop_toBottomOf="@id/katalogHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
