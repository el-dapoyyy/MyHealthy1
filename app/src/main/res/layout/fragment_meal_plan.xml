<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_green"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meal Plan"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="20sp"
                android:fontFamily="@font/exo2_extrabold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rekomendasi menu harian sehat"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:alpha="0.9"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Sarapan Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌅 Sarapan"
                android:textColor="@color/neon_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/containerSarapan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

            <!-- Makan Siang Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️ Makan Siang"
                android:textColor="@color/neon_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/containerSiang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

            <!-- Makan Malam Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙 Makan Malam"
                android:textColor="@color/neon_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/containerMalam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

            <!-- Snack Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍎 Snack"
                android:textColor="@color/neon_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/containerSnack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
