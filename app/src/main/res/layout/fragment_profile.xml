<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ════════════════════════════════════ -->
        <!-- HEADER: Avatar + Name + Title       -->
        <!-- ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="16dp">

            <!-- Avatar: Photo or Initials -->
            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <!-- Google Photo -->
                <ImageView
                    android:id="@+id/ivProfilePhoto"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Profile Photo" />

                <!-- Initials fallback -->
                <FrameLayout
                    android:id="@+id/flInitials"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_circle_border"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="@color/neon_primary"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/exo2_extrabold" />
                </FrameLayout>
            </FrameLayout>

            <!-- Level badge pill -->
            <TextView
                android:id="@+id/tvLevelBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRO"
                android:textColor="@color/neon_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_streak_pill"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginTop="-8dp" />

            <!-- Name -->
            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginTop="12dp" />

            <!-- Subtitle: Title + Level -->
            <TextView
                android:id="@+id/tvProfileSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ELITE RUNNER • PRO LEVEL 1"
                android:textColor="@color/neon_primary"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginTop="4dp" />

            <!-- Email (hidden but kept for logic) -->
            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@example.com"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <!-- Edit Profile Button -->
            <TextView
                android:id="@+id/btnEditProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️ Edit Nama"
                android:textColor="@color/neon_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_streak_pill"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ════════════════════════════════════ -->
        <!-- CURRENT LEVEL CARD                  -->
        <!-- ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_progress_card_dark"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Left: current level -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT LEVEL"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                    <TextView
                        android:id="@+id/tvStatsLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="@android:color/white"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/exo2_extrabold" />
                </LinearLayout>

                <!-- Right: next level -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEXT LEVEL"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                    <TextView
                        android:id="@+id/tvXpToNext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP TO 2"
                        android:textColor="@color/neon_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/exo2_extrabold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/xpLevelProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="16dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_linear_progress_green" />
        </LinearLayout>

        <!-- ════════════════════════════════════ -->
        <!-- STREAK & RANK ROW                   -->
        <!-- ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_progress_card_dark"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_badge_icon"
                        android:gravity="center"
                        android:text="🔥"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT STREAK"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:id="@+id/tvStatsStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/exo2_extrabold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" DAYS"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Rank / Badges -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_progress_card_dark"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_badge_icon"
                        android:gravity="center"
                        android:text="🏆"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RANK"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatsBadges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/6"
                    android:textColor="@android:color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BADGES"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </LinearLayout>

        <!-- ════════════════════════════════════ -->
        <!-- VITALS & ANALYTICS                  -->
        <!-- ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VITALS &amp; ANALYTICS"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold" />
                <TextView
                    android:id="@+id/btnEditData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EDIT DATA"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Weight & Height Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Weight -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WEIGHT"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/tvHealthWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/exo2_extrabold" />
                        <TextView
                            android:id="@+id/tvWeightUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" KG"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Height -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEIGHT"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/tvHealthHeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/exo2_extrabold" />
                        <TextView
                            android:id="@+id/tvHeightUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" CM"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- BMI & Age Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- BMI -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BMI"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/tvHealthBmi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/exo2_extrabold" />
                        <TextView
                            android:id="@+id/tvBmiCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" NORMAL"
                            android:textColor="@color/neon_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Age -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AGE"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/exo2_extrabold" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/tvAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/exo2_extrabold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" YRS"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ════════════════════════════════════ -->
        <!-- ACCOUNT INFO (collapsed)            -->
        <!-- ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_progress_card_dark"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT INFO"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginBottom="12dp" />

            <!-- Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Name"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvInfoName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="-"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <!-- Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Email"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvInfoEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="-"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <!-- Provider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Login via"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvInfoProvider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="-"
                    android:textColor="@color/neon_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <!-- Calorie Target -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Daily Cal Target"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvHealthCalTarget"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="-"
                    android:textColor="@color/neon_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Total XP card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_progress_card_dark"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_badge_icon"
                android:gravity="center"
                android:text="⚡"
                android:textSize="12sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total XP"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvStatsXp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 XP"
                android:textColor="@color/neon_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold" />
        </LinearLayout>

        <!-- ════════════════════════════════════ -->
        <!-- ABOUT + LOGOUT                      -->
        <!-- ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_progress_card_dark"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MyHealthy v1.0"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2026 Daffa"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Logout Button -->
        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="LOGOUT"
            android:textColor="#FF3B30"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/exo2_extrabold"
            android:background="@drawable/bg_button_logout_red_outline"
            android:clickable="true"
            android:focusable="true" />

        <!-- Delete Account -->
        <TextView
            android:id="@+id/btnDeleteAccount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="⚠️ DELETE ACCOUNT ⚠️"
