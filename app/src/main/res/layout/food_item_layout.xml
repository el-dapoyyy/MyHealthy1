<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#008B02">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <!-- FOTO: persegi + rounded -->
        <ImageView
            android:id="@+id/foodImage"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:background="@drawable/bg_food_image_rounded"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/default_image" />

        <!-- NAMA: putih + font Exo2 -->
        <TextView
            android:id="@+id/foodName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Nama Makanan"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:fontFamily="@font/exo2_semibold" />

        <!-- RATING (biar kontras, putih juga) -->
        <TextView
            android:id="@+id/tvRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="⭐ 5.0/5.0"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/exo2_regular" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
