<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp">

        <!-- Back Arrow (top-left) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="40dp"
            android:paddingBottom="4dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="4dp"
                android:rotation="90"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true"
                android:tint="@color/neon_primary" />
        </FrameLayout>

        <!-- Logo with Glow Ring -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="10dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_logo_glow_circle" />

            <ImageView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_gravity="center"
                android:src="@drawable/logo_sayur"
                android:contentDescription="Logo" />
        </FrameLayout>

        <!-- Title with Neon Glow Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up for your better diet"
            android:textSize="22sp"
            android:textColor="@color/neon_primary"
            android:textStyle="bold"
            android:fontFamily="@font/exo2_extrabold"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:textAlignment="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track nutrition, reach your goals"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/exo2_extrabold"
            android:layout_marginBottom="24dp"
            android:textAlignment="center" />

        <!-- Glowing Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_login_glow_card"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Full Name Input with Glow -->
            <EditText
                android:id="@+id/register_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Full name"
                android:inputType="textPersonName"
                android:maxLength="50"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_input_neon_glow"
                android:textColorHint="@color/text_secondary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Email Input with Glow -->
            <EditText
                android:id="@+id/register_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:maxLength="50"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_input_neon_glow"
                android:textColorHint="@color/text_secondary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Password Input with Glow -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/register_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:maxLength="30"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/exo2_extrabold"
                    android:background="@drawable/bg_input_neon_glow"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="16dp"
                    android:paddingEnd="48dp" />

                <ImageView
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_eye_off"
                    android:contentDescription="Toggle password"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>

            <!-- Confirm Password Input with Glow -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/register_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Confirm Password"
                    android:inputType="textPassword"
                    android:maxLength="30"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/exo2_extrabold"
                    android:background="@drawable/bg_input_neon_glow"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="16dp"
                    android:paddingEnd="48dp" />

                <ImageView
                    android:id="@+id/btn_toggle_confirm"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_eye_off"
                    android:contentDescription="Toggle confirm password"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>

            <!-- Sign Up Button with Glow -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/register_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sign Up"
                android:textColor="@color/text_inverse"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_button_neon_glow"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp" />

            <!-- Register with Google (Glow) -->
            <LinearLayout
                android:id="@+id/btn_google_sign_up"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_google_glow"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/icon_google"
                    android:contentDescription="Google" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register with google"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Sudah punya akun? Login -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sudah punya akun? "
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold" />

            <TextView
                android:id="@+id/tv_go_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textColor="@color/neon_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
