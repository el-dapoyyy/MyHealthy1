<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Form Container -->
    <LinearLayout
        android:id="@+id/register_form"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:padding="16dp"
        android:background="@drawable/rounded_form"
        android:elevation="6dp"
        android:gravity="center"
        android:clipToPadding="true"
        android:paddingBottom="20dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/logo_sayur"
            android:layout_marginBottom="8dp"
            android:layout_gravity="center"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:fontFamily="@font/exo2_extrabold"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="14dp" />

        <!-- Name Input -->
        <EditText
            android:id="@+id/register_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nama Lengkap"
            android:inputType="textPersonName"
            android:maxLength="50"
            android:singleLine="true"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textColor="#000000"
            android:fontFamily="@font/exo2_extrabold"
            android:background="@drawable/rounded_edittext"
            android:textColorHint="#66000000"
            android:layout_marginBottom="8dp" />

        <!-- Email Input -->
        <EditText
            android:id="@+id/register_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:maxLength="50"
            android:singleLine="true"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textColor="#000000"
            android:fontFamily="@font/exo2_extrabold"
            android:background="@drawable/rounded_edittext"
            android:textColorHint="#66000000"
            android:layout_marginBottom="8dp" />

        <!-- Password Input -->
        <EditText
            android:id="@+id/register_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:maxLength="30"
            android:singleLine="true"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textColor="#000000"
            android:fontFamily="@font/exo2_extrabold"
            android:background="@drawable/rounded_edittext"
            android:textColorHint="#66000000"
            android:layout_marginBottom="8dp" />

        <!-- Confirm Password Input -->
        <EditText
            android:id="@+id/register_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Konfirmasi Password"
            android:inputType="textPassword"
            android:maxLength="30"
            android:singleLine="true"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textColor="#000000"
            android:fontFamily="@font/exo2_extrabold"
            android:background="@drawable/rounded_edittext"
            android:textColorHint="#66000000" />

    </LinearLayout>

    <!-- Register Button -->
    <Button
        android:id="@+id/register_button"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_below="@id/register_form"
        android:layout_marginTop="10dp"
        android:text="REGISTER"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#0A8B02"
        android:fontFamily="@font/exo2_extrabold"
        android:layout_centerHorizontal="true" />

    <!-- Link to Login -->
    <TextView
        android:id="@+id/tv_go_to_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/register_button"
        android:layout_marginTop="14dp"
        android:layout_centerHorizontal="true"
        android:text="Sudah punya akun? Login"
        android:textColor="#008B02"
        android:textSize="14sp"
        android:fontFamily="@font/exo2_extrabold"
        android:clickable="true"
        android:focusable="true" />

</RelativeLayout>
