<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="32dp">

        <!-- Back Arrow -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="24dp"
            android:rotation="90"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp"
            android:text="Register"
            android:textSize="28sp"
            android:textColor="#008B02"
            android:textStyle="bold"
            android:fontFamily="@font/exo2_extrabold" />

        <!-- Name Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Name icon" />

            <EditText
                android:id="@+id/register_name"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Full name"
                android:inputType="textPersonName"
                android:maxLength="50"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@null"
                android:textColorHint="#999999"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Email Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_email"
                android:contentDescription="Email icon" />

            <EditText
                android:id="@+id/register_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:maxLength="50"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@null"
                android:textColorHint="#999999"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Password Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock"
                android:contentDescription="Password icon" />

            <EditText
                android:id="@+id/register_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Password"
                android:inputType="textPassword"
                android:maxLength="30"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@null"
                android:textColorHint="#999999"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Confirm Password Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="30dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock"
                android:contentDescription="Confirm password icon" />

            <EditText
                android:id="@+id/register_confirm_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Confirm Password"
                android:inputType="textPassword"
                android:maxLength="30"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@null"
                android:textColorHint="#999999"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Sign Up Button (Green Pill) -->
        <Button
            android:id="@+id/register_button"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:text="Sign up"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/exo2_extrabold"
            android:background="@drawable/bg_button_green_pill"
            android:stateListAnimator="@null"
            android:layout_marginBottom="24dp" />

        <!-- "Or Sign up with" separator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Or Sign up with  "
                android:textColor="#999999"
                android:textSize="12sp"
                android:fontFamily="@font/exo2_extrabold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- Google Sign-Up (Circle) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/btn_google_sign_up"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:background="@drawable/bg_google_button"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_google"
                    android:contentDescription="Google" />
            </LinearLayout>
        </LinearLayout>

        <!-- "Already have an account? Sign in" -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#999999"
                android:textSize="13sp"
                android:fontFamily="@font/exo2_extrabold" />

            <TextView
                android:id="@+id/tv_go_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in"
                android:textColor="#008B02"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
