<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#008B02"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp">

        <!-- Back Arrow (top-left) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:rotation="90"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true"
                android:tint="#FFFFFF" />
        </FrameLayout>

        <!-- Logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/logo_sayur"
            android:contentDescription="Logo" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up for your better diet"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="@font/exo2_extrabold"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:textAlignment="center" />

        <!-- White Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white_rounded"
            android:padding="20dp"
            android:elevation="4dp">

            <!-- Full Name Input -->
            <EditText
                android:id="@+id/register_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Full name"
                android:inputType="textPersonName"
                android:maxLength="50"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_input_gray"
                android:textColorHint="#999999"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Email Input -->
            <EditText
                android:id="@+id/register_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:maxLength="50"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_input_gray"
                android:textColorHint="#999999"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Password Input with Toggle -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/register_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:maxLength="30"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:fontFamily="@font/exo2_extrabold"
                    android:background="@drawable/bg_input_gray"
                    android:textColorHint="#999999"
                    android:paddingStart="16dp"
                    android:paddingEnd="48dp" />

                <ImageView
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_eye_off"
                    android:contentDescription="Toggle password"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>

            <!-- Confirm Password Input with Toggle -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/register_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Confirm Password"
                    android:inputType="textPassword"
                    android:maxLength="30"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:fontFamily="@font/exo2_extrabold"
                    android:background="@drawable/bg_input_gray"
                    android:textColorHint="#999999"
                    android:paddingStart="16dp"
                    android:paddingEnd="48dp" />

                <ImageView
                    android:id="@+id/btn_toggle_confirm"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_eye_off"
                    android:contentDescription="Toggle confirm password"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>

            <!-- Sign Up Button (#008B02) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/register_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sign Up"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_button_green"
                android:stateListAnimator="@null"
                android:layout_marginBottom="10dp" />

            <!-- Register with Google -->
            <LinearLayout
                android:id="@+id/btn_google_sign_up"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_google_row"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/icon_google"
                    android:contentDescription="Google" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register with google"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Hidden tv_go_to_login (kept for Java compatibility) -->
        <TextView
            android:id="@+id/tv_go_to_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
