<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_green"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progres Harian"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="20sp"
                android:fontFamily="@font/exo2_extrabold" />

            <!-- Streak + Level Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 Streak: 0 Hari"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ Lv.1 Pemula"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- XP Bar -->
            <ProgressBar
                android:id="@+id/xpProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_xp_bar"
                android:background="@drawable/bg_xp_bar_bg" />

            <TextView
                android:id="@+id/tvXp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 100 XP"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Content padding -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- === 3 Circular Progress === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <com.example.myhealthy.CircularProgressView
                    android:id="@+id/progressSteps"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1" />

                <com.example.myhealthy.CircularProgressView
                    android:id="@+id/progressCalories"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1" />

                <com.example.myhealthy.CircularProgressView
                    android:id="@+id/progressWater"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- === Mood Tracker === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bagaimana perasaanmu hari ini?"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/moodContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center" />
            </LinearLayout>

            <!-- === Quick Actions === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAddWater"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="💧 + Air"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_green"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="6dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnUpdateWeight"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="⚖️ Berat"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_dark"
                        android:stateListAnimator="@null"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- === Sleep Log === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😴 Durasi Tidur"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvSleepHours"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="- jam"
                        android:textColor="#008B02"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/exo2_extrabold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnLogSleep"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Catat Tidur"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@drawable/bg_button_green"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- === FASE 2: Statistik Mingguan === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Kalori Mingguan"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginBottom="8dp" />

                <com.example.myhealthy.WeeklyBarChartView
                    android:id="@+id/weeklyChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- === Weight Trend === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚖️ Tren Berat Badan"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginBottom="8dp" />

                <com.example.myhealthy.WeightTrendView
                    android:id="@+id/weightTrend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- === FASE 3: Badges === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆 Badges"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/badgeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- === BMI Info === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_progress_card"
                android:elevation="3dp"
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Info dari Kalkulator"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvBmiInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum ada data. Gunakan Kalkulator terlebih dahulu."
                    android:textColor="#666666"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvCalorieTarget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#008B02"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
