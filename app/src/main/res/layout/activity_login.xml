<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#008B02">

    <!-- Green Top Section with Logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="50dp"
        android:paddingBottom="60dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logo_sayur"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to HEALTHYBITE"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="@font/exo2_extrabold"
            android:layout_marginTop="10dp" />
    </LinearLayout>

    <!-- White Bottom Section (curved top) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="190dp"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_white_top_rounded"
            android:paddingTop="28dp"
            android:paddingBottom="32dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:gravity="center_horizontal">

            <!-- Title "Log in" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log in"
                android:textSize="28sp"
                android:textColor="#008B02"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:layout_marginBottom="28dp" />

            <!-- Email Input -->
            <EditText
                android:id="@+id/login_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:maxLength="50"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_input_gray"
                android:textColorHint="#999999"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Password Input -->
            <EditText
                android:id="@+id/login_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Password"
                android:inputType="textPassword"
                android:maxLength="30"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_input_gray"
                android:textColorHint="#999999"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Login Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/login_button"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Log in"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/exo2_extrabold"
                android:background="@drawable/bg_button_green"
                android:stateListAnimator="@null"
                android:layout_marginBottom="24dp" />

            <!-- "Atau login dengan" separator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="18dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Atau login dengan  "
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:fontFamily="@font/exo2_extrabold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0" />
            </LinearLayout>

            <!-- Google Sign-In (Circle with G logo) -->
            <LinearLayout
                android:id="@+id/btn_google_sign_in"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:gravity="center"
                android:background="@drawable/bg_circle_border"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="22dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_google"
                    android:contentDescription="Google" />
            </LinearLayout>

            <!-- "Belum punya akun? Register" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum punya akun? "
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold" />

                <TextView
                    android:id="@+id/tv_go_to_register"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register"
                    android:textColor="#008B02"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/exo2_extrabold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
