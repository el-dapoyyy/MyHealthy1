<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Form Container (Card-like with Rounded Corners) -->
    <LinearLayout
        android:id="@+id/login_form"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="135dp"
        android:padding="16dp"
        android:background="@drawable/rounded_form"
        android:elevation="6dp"
        android:gravity="center"
        android:clipToPadding="true"
        android:paddingBottom="20dp">

    <!-- Logo Inside the Form -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/logo_sayur"
        android:layout_marginBottom="10dp"
        android:layout_gravity="center"/>
        
    <TextView
        android:id="@+id/welcome_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to\n HealthyBite"
        android:fontFamily="@font/exo2_extrabold"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="10dp"/>


    <!-- Username Input -->
    <EditText
        android:id="@+id/username"
        android:layout_width="match_parent"
        android:hint="Enter your name"
        android:inputType="text"
        android:maxLength="25"
        android:singleLine="true"
        android:lines="1"
        android:textAlignment="center"
        android:textSize="16sp"
        android:layout_height="50dp"
        android:fontFamily="@font/exo2_extrabold"
        android:background="@drawable/rounded_edittext"
        android:textColorHint="#66000000"/>
    
    </LinearLayout>

    <!-- Login Button (Rounded with Green Color) -->
    <Button
        android:id="@+id/login_button"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_below="@id/login_form"
        android:layout_marginTop="10dp"
        android:text="START!"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#0A8B02"
        android:fontFamily="@font/exo2_extrabold"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
