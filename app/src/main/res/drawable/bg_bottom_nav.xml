<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom navigation background with rounded top corners and neon glow edge -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top edge glow line (neon green gradient facing upward) -->
    <item android:bottom="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1.5dp" android:color="#4D00FF85" />
            <corners android:topLeftRadius="20dp" android:topRightRadius="20dp" />
        </shape>
    </item>
    <!-- Outer glow border -->
    <item android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="#1A00FF85" />
            <corners android:topLeftRadius="18dp" android:topRightRadius="18dp" />
        </shape>
    </item>
    <!-- Core background fill -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#061A0D" />
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
        </shape>
    </item>
</layer-list>
