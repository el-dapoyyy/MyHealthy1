<?xml version="1.0" encoding="utf-8"?>
<!-- Input field with neon glow border for login/register -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer soft glow -->
    <item android:top="-1dp" android:bottom="-1dp" android:left="-1dp" android:right="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="3dp" android:color="@color/neon_glow_10" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Inner glow border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/input_bg" />
            <stroke android:width="1.5dp" android:color="@color/neon_glow_30" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
