<?xml version="1.0" encoding="utf-8"?>
<!-- Gender toggle button - SELECTED (Neon Green with glow) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow layer -->
    <item android:top="-2dp" android:bottom="-3dp" android:left="-2dp" android:right="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="#2200FF85" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Solid selected -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00FF85" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
