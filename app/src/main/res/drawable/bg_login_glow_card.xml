<?xml version="1.0" encoding="utf-8"?>
<!-- Login/Register form card with neon glow border (like scanner card) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer faint glow ~10% -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="6dp" android:color="#1A00FF85" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Inner blur glow ~30% -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="3dp" android:color="#4D00FF85" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <!-- Core card background -->
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A1E10" />
            <stroke android:width="1dp" android:color="#00FF85" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
