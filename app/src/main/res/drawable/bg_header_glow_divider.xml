<?xml version="1.0" encoding="utf-8"?>
<!-- Header glow divider: neon glow line fading downward -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top solid neon line -->
    <item android:height="1.5dp" android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="#00FF85" />
        </shape>
    </item>
    <!-- Glow layer 1 (~30% alpha) -->
    <item android:height="3dp" android:top="1dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#4D00FF85"
                android:endColor="#00001204"
                android:angle="270" />
        </shape>
    </item>
    <!-- Glow layer 2 (~10% alpha, wider spread) -->
    <item android:height="8dp" android:top="3dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A00FF85"
                android:endColor="#00001204"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
