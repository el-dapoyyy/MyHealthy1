<?xml version="1.0" encoding="utf-8"?>
<!-- Logo circle with neon glow ring -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="4dp" android:color="#1A00FF85" />
        </shape>
    </item>
    <!-- Inner glow ring -->
    <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="2dp" android:color="#4D00FF85" />
        </shape>
    </item>
    <!-- Core circle -->
    <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
        <shape android:shape="oval">
            <solid android:color="#0A1E10" />
            <stroke android:width="1dp" android:color="#00FF85" />
        </shape>
    </item>
</layer-list>
