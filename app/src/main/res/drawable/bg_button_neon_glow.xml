<?xml version="1.0" encoding="utf-8"?>
<!-- Neon glow button: layered glow effect behind solid neon button -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow layer (faint) -->
    <item android:top="2dp" android:bottom="-4dp" android:left="-2dp" android:right="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_glow_10" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Inner glow layer -->
    <item android:top="1dp" android:bottom="-2dp" android:left="-1dp" android:right="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_glow_20" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Core solid button -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_primary" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
