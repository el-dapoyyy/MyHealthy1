<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <stroke android:width="6dp" android:color="#0D00FF85" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Inner glow -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape>
            <solid android:color="@android:color/transparent" />
            <stroke android:width="3dp" android:color="#1A00FF85" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Core card -->
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape>
            <solid android:color="#0D1A12" />
            <stroke android:width="1dp" android:color="#2600FF85" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
