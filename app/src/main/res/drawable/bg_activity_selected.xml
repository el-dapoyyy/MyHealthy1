<?xml version="1.0" encoding="utf-8"?>
<!-- Activity option - SELECTED (subtle neon border + dark fill) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="3dp" android:color="#2200FF85" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Core -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D2E18" />
            <stroke android:width="1dp" android:color="#00FF85" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
