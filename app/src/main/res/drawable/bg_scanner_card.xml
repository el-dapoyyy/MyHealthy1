<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Lapisan Cahaya Luar Cekung (Outer Faint Glow) -->
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <stroke android:width="8dp" android:color="#1AFFD700" /> <!-- Alpha redup ~10% -->
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Lapisan Cahaya Dalam (Inner Blur Glow) -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape>
            <solid android:color="@android:color/transparent" />
            <stroke android:width="4dp" android:color="#4DFFD700" /> <!-- Alpha ~30% -->
            <corners android:radius="15dp" />
        </shape>
    </item>

    <!-- Inti Utama (Core Solid Stroke & Background Blur) -->
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape>
            <solid android:color="#AA151515" />
            <stroke android:width="1dp" android:color="#FFD700" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
